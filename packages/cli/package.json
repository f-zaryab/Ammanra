{
  "name": "ammanra",
  "version": "1.0.0",
  "description": "CLI to install UI components into Next.js apps",
  "type": "module",
  "bin": {
    "ammanra": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --clean",
    "dev": "tsdown src/index.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "tsdown": {
    "fixedExtension": false
  },
  "keywords": [
    "cli",
    "ui",
    "nextjs",
    "components"
  ],
  "author": "zaryab",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "kleur": "^4.1.5",
    "ora": "^9.3.0"
  }
}
